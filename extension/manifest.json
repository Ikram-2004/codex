{
  "manifest_version": 3,
  "name": "SecurePulse — Instant Security Scanner",
  "version": "1.0.0",
  "description": "Scan any website for vulnerabilities, XSS, SQL injection, and more — directly from your browser toolbar. Powered by SecurePulse.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "SecurePulse Scanner"
  },
  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "alarms",
    "contextMenus"
  ],
  "host_permissions": [
    "https://securepulse-backend.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
